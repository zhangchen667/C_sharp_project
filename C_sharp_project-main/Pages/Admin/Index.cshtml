@page
@model MyPersonalSpace.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "管理后台";
}

<h1 class="mb-4">管理后台</h1>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">博文数量</h5>
                <p class="card-text display-4 text-primary">@Model.TotalPosts</p>
            </div>
            <div class="card-footer">
                <a asp-page="../Posts/Create" class="btn btn-sm btn-primary">发布新博文</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">照片数量</h5>
                <p class="card-text display-4 text-success">@Model.TotalPhotos</p>
            </div>
            <div class="card-footer">
                <a asp-page="../Albums/Upload" class="btn btn-sm btn-success">上传照片</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">留言总数</h5>
                <p class="card-text display-4 text-info">@Model.TotalComments</p>
            </div>
            <div class="card-footer">
                <a asp-page="ManageComments" class="btn btn-sm btn-info">管理留言</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">待回复</h5>
                <p class="card-text display-4 text-warning">@Model.CommentsToReply</p>
            </div>
            <div class="card-footer">
                <a asp-page="ManageComments" class="btn btn-sm btn-warning">去回复</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                快捷操作
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">
                    <a asp-page="../Posts/Index" class="text-decoration-none">查看所有博文</a>
                </li>
                <li class="list-group-item">
                    <a asp-page="../Albums/Index" class="text-decoration-none">查看所有照片</a>
                </li>
                <li class="list-group-item">
                    <a asp-page="../Comments/Index" class="text-decoration-none">查看留言板</a>
                </li>
            </ul>
        </div>
    </div>
</div>
