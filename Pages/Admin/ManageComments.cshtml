@page
@model MyPersonalSpace.Pages.Admin.ManageCommentsModel

@{
    ViewData["Title"] = "管理留言";
}

<h1 class="mb-4">管理留言</h1>

<p>
    <a asp-page="./Index" class="btn btn-secondary">返回管理首页</a>
</p>

@if (!Model.Comments.Any())
{
    <div class="alert alert-info">暂无留言</div>
}
else
{
    @foreach (var comment in Model.Comments)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">
                    @comment.AuthorName
                    <small class="text-muted"> - @comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                    <span class="float-end">
                        <form method="post" asp-page-handler="Delete" asp-route-id="@comment.Id" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('确定删除吗？')">删除</button>
                        </form>
                    </span>
                </h6>
                <p class="card-text">@comment.Content</p>
                @if (!string.IsNullOrEmpty(comment.Reply))
                {
                    <div class="alert alert-success mt-2">
                        <strong>已回复：</strong> @comment.Reply
                    </div>
                }
                else
                {
                    <form method="post" asp-page-handler="Reply" asp-route-id="@comment.Id" class="mt-2">
                        <div class="input-group">
                            <input type="text" name="reply" class="form-control" placeholder="输入回复内容..." required />
                            <button type="submit" class="btn btn-primary">回复</button>
                        </div>
                    </form>
                }
            </div>
        </div>
    }
}
