@page
@model MyPersonalSpace.Pages.Identity.Account.LogoutModel
@{
    ViewData["Title"] = "退出登录";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow text-center">
            <div class="card-header bg-info text-white">
                <h3 class="card-title mb-0">退出登录</h3>
            </div>
            <div class="card-body">
                <p>您已成功退出登录</p>
                <a asp-page="/Index" class="btn btn-primary">返回首页</a>
            </div>
        </div>
    </div>
</div>
