@page
@model IndexModel

@{
    ViewData["Title"] = "首页";
}

<div class="text-center py-5">
    <h1 class="display-4 mb-4">欢迎来到我的个人空间</h1>
    <p class="lead mb-5">记录生活，分享技术，留存美好</p>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
    <div class="col">
        <div class="card h-100 text-center shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-primary"><i class="bi bi-file-text"></i> 博文</h3>
                <p class="card-text">记录技术心得与生活感悟</p>
                <a asp-page="/Posts/Index" class="btn btn-outline-primary">浏览博文</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 text-center shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-success"><i class="bi bi-images"></i> 相册</h3>
                <p class="card-text">记录美好瞬间的地方</p>
                <a asp-page="/Albums/Index" class="btn btn-outline-success">浏览相册</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 text-center shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-info"><i class="bi bi-chat-dots"></i> 留言</h3>
                <p class="card-text">欢迎留言交流互动</p>
                <a asp-page="/Comments/Index" class="btn btn-outline-info">去留言</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-body text-center">
                <h5 class="card-title">技术栈</h5>
                <p class="card-text">
                    本项目基于 ASP.NET Core Razor Pages 构建，
                    使用 SQLite 数据库，集成了面向对象设计、
                    Linq 查询、文件操作、正则表达式验证、
                    异步编程和全局异常处理等技术特性。
                </p>
            </div>
        </div>
    </div>
</div>

