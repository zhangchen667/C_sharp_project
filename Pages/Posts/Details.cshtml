@page "{id}"
@model MyPersonalSpace.Pages.Posts.DetailsModel

@{
    ViewData["Title"] = Model.Post.Title;
}

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <article>
            <h1 class="mb-3">@Model.Post.Title</h1>
            <div class="text-muted mb-4">
                <span>分类: @Model.Post.Category?.Name</span> |
                <span>作者: @Model.Post.Author?.UserName</span> |
                <span>发布时间: @Model.Post.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
            </div>
            <div class="card">
                <div class="card-body">
                    @Html.Raw(Model.Post.Content.Replace("\n", "<br />"))
                </div>
            </div>
            <div class="mt-3">
                <a asp-page="./Index" class="btn btn-secondary">返回列表</a>
            </div>
        </article>
    </div>
</div>
